# =============================================
# .htaccess for highlinnfarms.com
# =============================================
# Apache reads this file when serving the site and applies the
# directives below to every request handled out of this folder
# (and its subfolders, unless overridden by another .htaccess).

# Tell browsers to interpret text files as UTF-8 so em-dashes,
# fractions, accented characters, and other non-ASCII content
# display correctly instead of as garbled "â€"" mojibake.
#
# AddDefaultCharset only covers text/html and text/plain, so we
# also need AddCharset to extend the same behavior to JavaScript,
# CSS, JSON, and XML responses — otherwise scripts.js comes back
# without a declared charset and the browser falls back to its
# locale default (often Windows-1252), garbling the em-dashes.
AddDefaultCharset utf-8
AddCharset utf-8 .js .css .json .xml .svg

# Always have browsers re-check the server for fresh HTML pages
# instead of reusing a cached copy. Combined with the ?v=YYYY-MM-DD
# cache-busting labels on script/stylesheet references inside those
# pages, this guarantees that when you deploy a change, visitors see
# it on their next visit — not after their browser cache happens
# to expire on its own. Static assets (JS, CSS, images) can still be
# cached long-term, because their URLs change whenever you bump the
# version label.
<IfModule mod_headers.c>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
